<mvc:View xmlns:form="sap.ui.layout.form"
    controllerName="ypf.ypfui5hrsaldo.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:upload="sap.m.upload"
    xmlns="sap.m">

    <Page id="pgSolicitud" showHeader="false" class="customSolicitudPage">
        <content>
            <VBox id="bvtitle" class="sapUiSmallMargin sapUiSmallMarginTop">
        
            <Title id="title" text="{i18n>title}" level="H2" />

            <Text id="subtitle" text="{i18n>subtitle}"
                  class="customSubtitle sapUiTinyMarginTop sapUiSmallMarginBottom" />

        </VBox>

            <Wizard id="wizSolicitud" complete="onWizardComplete">

                <WizardStep
                    id="stpCabecera"
                    title="Cabecera"
                    validated="false"
                    activate=".onCabeceraValidacion">

                    <MessageStrip
                        id="msgCabecera"
                        class="sapUiSmallMarginBottom"
                        text="Ingresar los datos de Cabecera"
                        showIcon="true" />

                    <form:SimpleForm
                        id="frmCabecera"
                        editable="true"
                        layout="ResponsiveGridLayout">

                        <Label id="lblSociedad" text="Sociedad" required="true" />
                        <Input
                            id="inpSociedad"
                            placeholder="Seleccione sociedad"
                            showValueHelp="true"
                            valueHelpRequest=".onValueHelpSociedad"
                            change=".onCabeceraValidacion" />

                        <Label id="lblTipoSolicitud" text="Tipo de Solicitud" required="true" />
                        <ComboBox
                            id="cmbTipoSolicitud"
                            selectionChange=".onCabeceraValidacion">
                            <items>
                                <core:Item id="itemTipoSolicitudDefault" key="" text="Seleccione..." />
                                <core:Item id="itemTipoSolicitudMulta" key="1" text="Multa" />
                                <core:Item id="itemTipoSolicitudReintegro" key="2" text="Reintegro" />
                                <core:Item id="itemTipoSolicitudFondoReparo" key="3" text="Fondo de Reparo" />
                            </items>
                        </ComboBox>

                        <Label id="lblProveedor" text="Proveedor" required="true" />
                        <Input
                            id="inpProveedor"
                            placeholder="Seleccione proveedor"
                            showValueHelp="true"
                            valueHelpRequest=".onValueHelpProveedor"
                            change=".onCabeceraValidacion" />

                        <Label id="lblUbicacion" text="Ubicación" required="true" />
                        <ComboBox
                            id="cmbUbicacion"
                            selectionChange=".onCabeceraValidacion">
                            <items>
                                <core:Item id="itemUbicacionDefault" key="" text="Seleccione..." />
                                <core:Item id="itemUbicacionBuenosAiresResto" key="BA_RESTO" text="Buenos Aires - Resto" />
                                <core:Item id="itemUbicacionCaba" key="CABA" text="CABA" />
                                <core:Item id="itemUbicacionCordoba" key="CORDOBA" text="Córdoba" />
                                <core:Item id="itemUbicacionRosario" key="ROSARIO" text="Rosario" />
                            </items>
                        </ComboBox>

                    </form:SimpleForm>

                    <HBox id="boxAccionesCabecera" justifyContent="Center">
                        <Button
                            id="btnSiguienteCabecera"
                            text="Siguiente paso"
                            tooltip="Permite avanzar al siguiente paso de la solicitud"
                            type="Emphasized"
                            press=".onSiguientePaso1" />
                    </HBox>

                </WizardStep>

   <WizardStep
    id="stpInformacion"
    title="Informacion de Solicitud"
    validated="false"
    activate=".onInformacionValidacion">

    <MessageStrip
        id="msgInformacion"
        class="sapUiSmallMarginBottom"
        text="Ingresar los datos de Informacion"
        showIcon="true" />

    <VBox id="boxInformacion" class="sapUiSmallMargin">

        <Panel
            id="pnlDatosCabecera"
            headerText="Datos de cabecera"
            expandable="true"
            expanded="true"
            class="sapUiResponsiveMargin">

            <VBox id="boxDatosCabecera" class="sapUiSmallMargin">

                <Button
                    id="btnSolicitudMulta"
                    text="Solicitud de Multa"
                    type="Transparent"
                    icon="sap-icon://add"
                    class="sapUiTinyMarginBottom" />

                <layout:Grid
                    id="grdStep2"
                    width="100%"
                    hSpacing="2"
                    vSpacing="1">

                    <!-- COLUMNA IZQUIERDA -->
                    <VBox id="vbColumnaIzquierda" width="100%">
                        <layoutData>
                            <layout:GridData span="XL6 L6 M12 S12" />
                        </layoutData>

                        <HBox
                            id="hbSucursal"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblSucursal"
                                text="Sucursal:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpSucursal"
                                class="campoFormulario"
                                placeholder="Seleccione una Sucursal"
                                editable="false"
                                change=".onInformacionValidacion"
                                value="1101"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbPedido"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblPedido"
                                text="Pedido:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpPedido"
                                placeholder="Ingrese un nro pedido"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpPedido"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbHojaEntrada"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblHojaEntrada"
                                text="Hoja de entrada / serv.:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpHojaEntrada"
                                placeholder="Ingrese Hoja de Servicio"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbCentroCosto"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblCentroCosto"
                                text="Centro coste:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpCentroCosto"
                                placeholder="Seleccione un centro de Costo"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpCentroCosto"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbEjercicio"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblEjercicio"
                                text="Ejercicio:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpEjercicio"
                                placeholder="Ingresar un nro Ejercicio"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>
                    </VBox>

                    <!-- COLUMNA DERECHA -->
                    <VBox id="vbColumnaDerecha" width="100%">
                        <layoutData>
                            <layout:GridData span="XL6 L6 M12 S12" />
                        </layoutData>

                        <HBox
                            id="hbMoneda"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblMoneda"
                                text="Moneda:"
                                required="true"
                                width="170px" />
                            <ComboBox
                                id="cmbMoneda"
                                selectionChange=".onInformacionValidacion"
                                width="20rem">
                                <items>
                                    <core:Item id="itemMonedaDefault" key="" text="Seleccione..." />
                                    <core:Item id="itemMonedaArs" key="ARS" text="ARS" />
                                    <core:Item id="itemMonedaUsd" key="USD" text="USD" />
                                    <core:Item id="itemMonedaEur" key="EUR" text="EUR" />
                                </items>
                            </ComboBox>
                        </HBox>

                        <HBox
                            id="hbImporte"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblImporte"
                                text="Importe:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpImporte"
                                type="Number"
                                placeholder="Ingresar un Importe"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbReferencia"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblReferencia"
                                text="Referencia:"
                                width="170px" />
                            <Input
                                id="inpReferencia"
                                placeholder="Ingrese una referecia"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbCentroBeneficio"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblCentroBeneficio"
                                text="Centro de Beneficio:"
                                width="170px" />
                            <Input
                                id="inpCentroBeneficio"
                                placeholder="Ingrese Centro de Beneficio"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpCentroBeneficio"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>
                    </VBox>

                </layout:Grid>

            </VBox>
        </Panel>

        <HBox
            id="boxAccionesInformacion"
            justifyContent="Center"
            class="sapUiMediumMarginTop">

            <Button
                id="btnAnteriorInformacion"
                text="Paso anterior"
                tooltip="Permite regresar al paso anterior de la solicitud"
                press=".onPasoAnterior1"
                class="sapUiTinyMarginEnd" />

            <Button
                id="btnSiguienteInformacion"
                text="Siguiente paso"
                tooltip="Permite avanzar al siguiente paso de la solicitud"
                type="Emphasized"
                press=".onSiguientePaso2" />

        </HBox>

    </VBox>

</WizardStep>

                <WizardStep
                    id="stpComentarios"
                    title="Comentarios"
                    validated="false"
                    activate=".onComentariosValidacion">

                    <MessageStrip
                        id="msgComentarios"
                        class="sapUiSmallMarginBottom"
                        type="Information"
                        text="Agrega el comentario que creas necesario. Max caracteres 250"
                        showIcon="true" />

                    <form:SimpleForm id="frmComentarios">
                        <TextArea
                            id="txtaComentario"
                            placeholder="Escribí tu comentario aquí..."
                            rows="5"
                            maxLength="250"
                            liveChange=".onComentariosValidacion"
                            showExceededText="true"
                            width="100%" />
                    </form:SimpleForm>

                    <HBox
                        id="boxAccionesComentarios"
                        justifyContent="Center"
                        class="sapUiMediumMarginTop">

                        <Button
                            id="btnAnteriorComentarios"
                            text="Paso anterior"
                            tooltip="Permite regresar al paso anterior de la solicitud"
                            press=".onPasoAnterior2"
                            class="sapUiTinyMarginEnd" />

                        <Button
                            id="btnSiguienteComentarios"
                            text="Siguiente paso"
                            tooltip="Permite avanzar al siguiente paso de la solicitud"
                            type="Emphasized"
                            press=".onSiguientePaso3" />

                    </HBox>

                </WizardStep>

                <WizardStep id="stpAdjuntos" title="Adjuntos" validated="false" activate=".onAdjuntosValidacion">
                    <MessageStrip
                        id="msgAdjuntos"
                        class="sapUiSmallMarginBottom"
                        text="Ingresar los datos adjuntos"
                        showIcon="true" />

                        <upload:UploadSet id="us"
                                maxFileSize="25"
                                maxFileNameLength="120"
                                instantUpload="false"
                                afterItemAdded=".onAfterItemAdded"
                                beforeUploadStarts=".onBeforeUpload"
                                uploadCompleted=".onUploadCompleted"
                                afterItemRemoved=".onFileRemoved">
                        </upload:UploadSet>

                        <List id="listAdjuntos" items="{filesLocal>/items}" headerText="Adjuntos cargados">

    <StandardListItem id="listAdjuntos2"
        title="{filesLocal>fileName}"
        description="{filesLocal>mime}"
        info="{filesLocal>size}"
        icon="sap-icon://attachment" />

</List>

                           <HBox
                        id="boxAccionesAdjuntos"
                        justifyContent="Center"
                        class="sapUiMediumMarginTop">

                        <Button
                            id="btnAnteriorAdjuntos"
                            text="Paso anterior"
                            tooltip="Permite regresar al paso anterior de la solicitud"
                            press=".onPasoAnterior3"
                            class="sapUiTinyMarginEnd" />

                        <Button
                            id="btnSiguienteAdjuntos"
                            text="Siguiente paso"
                            tooltip="Permite avanzar al siguiente paso de la solicitud"
                            type="Emphasized"
                            press=".onSiguientePaso4" />

                    </HBox>


                </WizardStep>

                <WizardStep id="stpRevision" title="Revision" validated="true">
                    <MessageStrip
                        id="msgRevision"
                        class="sapUiSmallMarginBottom"
                        text="Revisar los datos ingresados en la solicitud"
                        showIcon="true" />
                </WizardStep>

            </Wizard>
        </content>

        <footer>
            <OverflowToolbar id="tbFooterSolicitud">
                <ToolbarSpacer id="spcFooter" />
                <Button
                    id="btnCancelarSolicitud"
                    text="Cancelar solicitud"
                    tooltip="Permite cancelar la carga de datos de la solicitud"
                    type="Reject"
                    press=".onCancelarSolicitud" />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>