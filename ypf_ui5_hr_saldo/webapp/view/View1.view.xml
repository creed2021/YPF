<mvc:View xmlns:form="sap.ui.layout.form"
    controllerName="ypf.ypfui5hrsaldo.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:upload="sap.m.upload"
    xmlns="sap.m">

    <Page id="pgSolicitud" showHeader="false" class="customSolicitudPage">
        <content>
            <VBox id="bvtitle" class="sapUiSmallMargin sapUiSmallMarginTop">
        
            <Title id="title" text="{i18n>title}" level="H2" />

            <Text id="subtitle" text="{i18n>subtitle}"
                  class="customSubtitle sapUiTinyMarginTop sapUiSmallMarginBottom" />

        </VBox>

            <Wizard id="wizSolicitud" complete="onWizardComplete">

               <WizardStep
    id="stpCabecera"
    title="Cabecera"
    validated="false"
    activate=".onCabeceraValidacion">

    <MessageStrip
        id="msgCabecera"
        class="sapUiSmallMarginBottom sapUiResponsiveMargin"
        text="Ingresar los datos de Cabecera"
        showIcon="true" />

    <VBox
        width="100%"
        alignItems="Center">

        <VBox width="60%">

            <form:SimpleForm
                id="frmCabecera"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="3"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="1"
                emptySpanL="1"
                emptySpanM="1"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false">

                <Label id="lblSociedad" text="Sociedad" required="true" />
                <Input
                    id="inpSociedad"
                    placeholder="Seleccione sociedad"
                    showValueHelp="true"
                    valueHelpRequest=".onValueHelpSociedad"
                    change=".onCabeceraValidacion" />

                <Label id="lblTipoSolicitud" text="Tipo de Solicitud" required="true" />
                <ComboBox
                    id="cmbTipoSolicitud"
                    width="100%"
                    selectionChange=".onTipoSolicitudChange">
                    <items>
                        <core:Item id="itemTipoSolicitudDefault" key="" text="Seleccione..." />
                        <core:Item id="itemTipoSolicitudMulta" key="1" text="Multa" />
                        <core:Item id="itemTipoSolicitudReintegro" key="2" text="Reintegro" />
                        <core:Item id="itemTipoSolicitudFondoReparo" key="3" text="Fondo de Reparo" />
                    </items>
                </ComboBox>

                <Label id="lblProveedor" text="Proveedor" required="true" />
                <Input
                    id="inpProveedor"
                    placeholder="Seleccione proveedor"
                    showValueHelp="true"
                    valueHelpRequest=".onValueHelpProveedor"
                    change=".onCabeceraValidacion" />

                <Label id="lblUbicacion" text="Ubicación" required="true" />
                <ComboBox
                    id="cmbUbicacion"
                    width="100%"
                    selectionChange=".onCabeceraValidacion">
                    <items>
                        <core:Item id="itemUbicacionDefault" key="" text="Seleccione..." />
                        <core:Item id="itemUbicacionBuenosAiresResto" key="BA_RESTO" text="Buenos Aires - Resto" />
                        <core:Item id="itemUbicacionCaba" key="CABA" text="CABA" />
                        <core:Item id="itemUbicacionCordoba" key="CORDOBA" text="Córdoba" />
                        <core:Item id="itemUbicacionRosario" key="ROSARIO" text="Rosario" />
                    </items>
                </ComboBox>

            </form:SimpleForm>

            <HBox
                id="boxAccionesCabecera"
                justifyContent="Center"
                class="sapUiMediumMarginTop">
                <Button
                    id="btnSiguienteCabecera"
                    text="Siguiente paso"
                    tooltip="Permite avanzar al siguiente paso de la solicitud"
                    type="Emphasized"
                    press=".onSiguientePaso1" />
            </HBox>

        </VBox>
    </VBox>

</WizardStep>

   <WizardStep
    id="stpInformacion"
    title="Informacion de Solicitud"
    validated="false"
    activate=".onInformacionValidacion">

    <MessageStrip
        id="msgInformacion"
        class="sapUiSmallMarginBottom"
        text="Ingresar los datos de Informacion"
        showIcon="true" />

    <VBox id="boxInformacion" class="sapUiSmallMargin" visible="{ui>/showMulta}">

        <Panel
            id="pnlDatosCabecera"
            headerText="Datos de cabecera"
            expandable="true"
            expanded="true"
            class="sapUiResponsiveMargin">

            <VBox id="boxDatosCabecera" class="sapUiSmallMargin">

                <Button
                    id="btnSolicitudMulta"
                    text="Solicitud de Multa"
                    type="Transparent"
                    icon="sap-icon://add"
                    class="sapUiTinyMarginBottom" />

                <layout:Grid
                    id="grdStep2"
                    width="100%"
                    hSpacing="2"
                    vSpacing="1">

                    <!-- COLUMNA IZQUIERDA -->
                    <VBox id="vbColumnaIzquierda" width="100%">
                        <layoutData>
                            <layout:GridData span="XL6 L6 M12 S12" />
                        </layoutData>

                        <HBox
                            id="hbSucursal"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblSucursal"
                                text="Sucursal:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpSucursal"
                                class="campoFormulario"
                                placeholder="Seleccione una Sucursal"
                                editable="false"
                                change=".onInformacionValidacion"
                                value="1101"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbPedido"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblPedido"
                                text="Pedido:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpPedido"
                                placeholder="Ingrese un nro pedido"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpPedido"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbHojaEntrada"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblHojaEntrada"
                                text="Hoja de entrada / serv.:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpHojaEntrada"
                                placeholder="Ingrese Hoja de Servicio"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbCentroCosto"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblCentroCosto"
                                text="Centro coste:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpCentroCosto"
                                placeholder="Seleccione un centro de Costo"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpCentroCosto"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbEjercicio"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblEjercicio"
                                text="Ejercicio:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpEjercicio"
                                placeholder="Ingresar un nro Ejercicio"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>
                    </VBox>

                    <!-- COLUMNA DERECHA -->
                    <VBox id="vbColumnaDerecha" width="100%">
                        <layoutData>
                            <layout:GridData span="XL6 L6 M12 S12" />
                        </layoutData>

                        <HBox
                            id="hbMoneda"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblMoneda"
                                text="Moneda:"
                                required="true"
                                width="170px" />
                            <ComboBox
                                id="cmbMoneda"
                                selectionChange=".onInformacionValidacion"
                                width="20rem">
                                <items>
                                    <core:Item id="itemMonedaDefault" key="" text="Seleccione..." />
                                    <core:Item id="itemMonedaArs" key="ARS" text="ARS" />
                                    <core:Item id="itemMonedaUsd" key="USD" text="USD" />
                                    <core:Item id="itemMonedaEur" key="EUR" text="EUR" />
                                </items>
                            </ComboBox>
                        </HBox>

                        <HBox
                            id="hbImporte"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblImporte"
                                text="Importe:"
                                required="true"
                                width="170px" />
                            <Input
                                id="inpImporte"
                                type="Number"
                                placeholder="Ingresar un Importe"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbReferencia"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblReferencia"
                                text="Referencia:"
                                width="170px" />
                            <Input
                                id="inpReferencia"
                                placeholder="Ingrese una referecia"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>

                        <HBox
                            id="hbCentroBeneficio"
                            alignItems="Center"
                            class="sapUiTinyMarginBottom"
                            width="100%">
                            <Label
                                id="lblCentroBeneficio"
                                text="Centro de Beneficio:"
                                width="170px" />
                            <Input
                                id="inpCentroBeneficio"
                                placeholder="Ingrese Centro de Beneficio"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpCentroBeneficio"
                                change=".onInformacionValidacion"
                                width="20rem" />
                        </HBox>
                    </VBox>

                </layout:Grid>

            </VBox>
        </Panel>

        <HBox
            id="boxAccionesInformacion"
            justifyContent="Center"
            class="sapUiMediumMarginTop">

            <Button
                id="btnAnteriorInformacion"
                text="Paso anterior"
                tooltip="Permite regresar al paso anterior de la solicitud"
                press=".onPasoAnterior1"
                class="sapUiTinyMarginEnd" />

            <Button
                id="btnSiguienteInformacion"
                text="Siguiente paso"
                tooltip="Permite avanzar al siguiente paso de la solicitud"
                type="Emphasized"
                press=".onSiguientePaso2" />

        </HBox>

    </VBox>

    <VBox id="boxInformacionReintegro" visible="{ui>/showReintegro}" class="sapUiSmallMargin">

    <Panel
        id="pnlDatosCabeceraReintegro"
        headerText="Datos de cabecera"
        expandable="true"
        expanded="true"
        class="sapUiResponsiveMargin">

        <VBox id="boxDatosCabeceraReintegro" class="sapUiSmallMargin">

            <Button
                id="btnSolicitudReintegro"
                text="Solicitud de Reintegro"
                type="Transparent"
                icon="sap-icon://add"
                class="sapUiTinyMarginBottom" />

            <layout:Grid
                id="grdStep2Reintegro"
                width="100%"
                hSpacing="2"
                vSpacing="1"
                defaultSpan="XL12 L12 M12 S12">

                <HBox
                    id="hbFiltrosReintegro"
                    wrap="Wrap"
                    class="sapUiSmallMarginBottom"
                    width="100%"
                    justifyContent="Start"
                    alignItems="End">

                    <VBox id="vbTipoSolicitudReintegro" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                        <Label
                            id="lblTipoSolicitudReintegro"
                            text="Tipo de Solicitud:"
                            required="true" />
                        <ComboBox
                            id="cmbTipoSolicitudReintegro"
                            width="12rem"
                            selectionChange=".onInformacionValidacion">
                            <items>
                                <core:Item id="itemTipoSolReintegroDefault" key="" text="Seleccione..." />
                                <core:Item id="itemTipoSolReintegroMulta" key="1" text="Multa" />
                                <core:Item id="itemTipoSolReintegroReintegro" key="2" text="Reintegro" />
                                <core:Item id="itemTipoSolReintegroFondo" key="3" text="Fondo de Reparo" />
                            </items>
                        </ComboBox>
                    </VBox>

                    <VBox id="vbNroPedidoReintegro" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                        <Label
                            id="lblNroPedidoReintegro"
                            text="Nro. Pedido:" />
                        <Input
                            id="inpNroPedidoReintegro"
                            width="12rem"
                            placeholder="Ingrese Nro. Pedido"
                            showValueHelp="true"
                            change=".onInformacionValidacion" />
                    </VBox>

                    <VBox id="vbHojaEntradaServReintegro" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                        <Label
                            id="lblHojaEntradaServReintegro"
                            text="Hoja de ent/serv.:" />
                        <Input
                            id="inpHojaEntradaServReintegro"
                            width="12rem"
                            placeholder="Seleccione Hoja de ent/serv."
                            change=".onInformacionValidacion" />
                    </VBox>

                    <VBox id="vbBuscarReintegro" class="sapUiSmallMarginBottom">
                        <Button
                            id="btnBuscarReintegro"
                            text="Buscar"
                            type="Emphasized"
                            press=".onBuscarReintegro" />
                    </VBox>

                </HBox>

                <VBox id="vbTablaSolicitudesReintegro" width="100%">
                    <Title
                        id="ttlSolicitudesReintegro"
                        text="Solicitudes (0)"
