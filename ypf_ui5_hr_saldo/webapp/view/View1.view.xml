                    </VBox>

                </layout:Grid>
            </HBox>

        </VBox>
    </Panel>

    <HBox
        id="boxAccionesInformacionFondoReparo"
        justifyContent="Center"
        class="sapUiMediumMarginTop">

        <Button
            id="btnAnteriorFondoReparo"
            text="Paso anterior"
            press=".onPasoAnterior1"
            class="sapUiTinyMarginEnd" />

        <Button
            id="btnSiguienteFondoReparo"
            text="Siguiente paso"
            type="Emphasized"
            press=".onSiguientePaso2" />
    </HBox>

</VBox>


</WizardStep>

                <WizardStep
                    id="stpComentarios"
                    title="Comentarios"
                    validated="false"
                    activate=".onComentariosValidacion">

                    <MessageStrip
                        id="msgComentarios"
                        class="sapUiSmallMarginBottom"
                        type="Information"
                        text="Agrega el comentario que creas necesario. Max caracteres 250"
                        showIcon="true" />

                    <form:SimpleForm id="frmComentarios">
                        <TextArea
                            id="txtaComentario"
                            placeholder="Escribí tu comentario aquí..."
                            rows="5"
                            maxLength="250"
                            liveChange=".onComentariosValidacion"
                            showExceededText="true"
                            width="100%" />
                    </form:SimpleForm>

                    <HBox
                        id="boxAccionesComentarios"
                        justifyContent="Center"
                        class="sapUiMediumMarginTop">

                        <Button
                            id="btnAnteriorComentarios"
                            text="Paso anterior"
                            tooltip="Permite regresar al paso anterior de la solicitud"
                            press=".onPasoAnterior2"
                            class="sapUiTinyMarginEnd" />

                        <Button
                            id="btnSiguienteComentarios"
                            text="Siguiente paso"
                            tooltip="Permite avanzar al siguiente paso de la solicitud"
                            type="Emphasized"
                            press=".onSiguientePaso3" />

                    </HBox>

                </WizardStep>

                <WizardStep id="stpAdjuntos" title="Adjuntos" validated="false" activate=".onAdjuntosValidacion">
                    <MessageStrip
                        id="msgAdjuntos"
                        class="sapUiSmallMarginBottom"
                        text="Ingresar los datos adjuntos"
                        showIcon="true" />

                        <upload:UploadSet id="us"
                                maxFileSize="25"
                                maxFileNameLength="120"
                                instantUpload="false"
                                afterItemAdded=".onAfterItemAdded"
                                beforeUploadStarts=".onBeforeUpload"
                                uploadCompleted=".onUploadCompleted"
                                afterItemRemoved=".onFileRemoved">
                        </upload:UploadSet>

                        <List id="listAdjuntos" items="{filesLocal>/items}" headerText="Adjuntos cargados">

    <StandardListItem id="listAdjuntos2"
        title="{filesLocal>fileName}"
        description="{filesLocal>mime}"
        info="{filesLocal>size}"
        icon="sap-icon://attachment" />

</List>

                           <HBox
                        id="boxAccionesAdjuntos"
                        justifyContent="Center"
                        class="sapUiMediumMarginTop">

                        <Button
                            id="btnAnteriorAdjuntos"
                            text="Paso anterior"
                            tooltip="Permite regresar al paso anterior de la solicitud"
                            press=".onPasoAnterior3"
                            class="sapUiTinyMarginEnd" />

                        <Button
                            id="btnSiguienteAdjuntos"
                            text="Siguiente paso"
                            tooltip="Permite avanzar al siguiente paso de la solicitud"
                            type="Emphasized"
                            press=".onSiguientePaso4" />

                    </HBox>


                </WizardStep>

                <WizardStep id="stpRevision" title="Revision" validated="true">
                    <MessageStrip
                        id="msgRevision"
                        class="sapUiSmallMarginBottom"
                        text="Revisar los datos ingresados en la solicitud"
