<mvc:View xmlns:form="sap.ui.layout.form" controllerName="ypf.ypfui5hrsaldo.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
      <content>
        <Wizard id="wizardId"  complete="onWizardComplete">

            <WizardStep id="PrimerStep" title="Cabecera" validated="false" activate=".onCabeceraValidacion">
                <MessageStrip id="M1" class="sapUiSmallMarginBottom"
										text="Ingresar los datos de Cabecera"
										showIcon="true"/>
                <form:SimpleForm id="FormCabecera" editable="true" layout="ResponsiveGridLayout">

                    <Label id="lblSociedad" text="Sociedad" required="true" />
                    <Input
                        id="inpSociedad"
                        placeholder="Seleccione sociedad"
                        showValueHelp="true"
                        valueHelpRequest=".onValueHelpSociedad"
                        change=".onCabeceraValidacion" />

                         <Label id="lblTipoSolicitud" text="Tipo de Solicitud" required="true" />
                    <ComboBox
                        id="cmbTipoSolicitud"
                        selectionChange=".onCabeceraValidacion">
                        <items>
                            <core:Item id="k6" key="" text="Seleccione..." />
                            <core:Item id="k7" key="MULTA" text="Multa" />
                            <core:Item id="k9" key="NC" text="Nota de Crédito" />
                            <core:Item id="k10" key="AJUSTE" text="Ajuste" />
                        </items>
                    </ComboBox>

                      <Label id="lblProveedor" text="Proveedor" required="true" />
                    <Input
                        id="inpProveedor"
                        placeholder="Seleccione proveedor"
                        showValueHelp="true"
                        valueHelpRequest=".onValueHelpProveedor"
                        change=".onCabeceraValidacion" />

                    <Label id="lblUbicacion" text="Ubicación" required="true" />
                    <ComboBox
                        id="cmbUbicacion"
                        selectionChange=".onCabeceraValidacion">
                        <items>
                            <core:Item id="k1" key="" text="Seleccione..." />
                            <core:Item id="k2" key="BA_RESTO" text="Buenos Aires - Resto" />
                            <core:Item id="k3" key="CABA" text="CABA" />
                            <core:Item id="k4" key="CORDOBA" text="Córdoba" />
                            <core:Item id="k5" key="ROSARIO" text="Rosario" />
                        </items>
                    </ComboBox>

                </form:SimpleForm>                        
            
                <HBox  id="p1" justifyContent="Center">


    <Button id="bt1"
        text="Siguiente paso"
        type="Emphasized"
        press=".onSiguientePaso1"/>

</HBox>

            </WizardStep>

              <WizardStep
    id="SegundoStep"
    title="Informacion de Solicitud"
    validated="false"
    activate=".onInformacionValidacion">

    <MessageStrip
        id="M2"
        class="sapUiSmallMarginBottom"
        text="Ingresar los datos de Informacion"
        showIcon="true"/>

    <VBox id="bt7" class="sapUiMediumMargin">

        <Title
            id="ttlStep2"
            text="2. Información de solicitud"
            level="H3"
            class="sapUiSmallMarginBottom"/>

        <Panel
            id="pnlDatosCabecera"
            headerText="Datos de cabecera"
            expandable="true"
            expanded="true"
            class="sapUiResponsiveMargin">

            <VBox id="br3" class="sapUiSmallMargin">

                <Button
                    id="btnSolicitudMulta"
                    text="Solicitud de Multa"
                    type="Transparent"
                    icon="sap-icon://add"
                    class="sapUiTinyMarginBottom"/>

                <layout:Grid
                    id="gridStep2"
                    xmlns:layout="sap.ui.layout"
                    defaultSpan="XL6 L6 M6 S12"
                    hSpacing="1"
                    vSpacing="1">

                    <VBox id="vbColumnaIzquierda">

                        <HBox id="hbSucursal" alignItems="Center" class="sapUiTinyMarginBottom">
                            <Label id="lblSucursal" text="Sucursal:" required="true" width="140px"/>
                            <Input
                                id="inpSucursal"
                                editable="false"
                                change=".onInformacionValidacion"
                                value="1101"
                                width="100%"/>
                        </HBox>

                        <HBox id="hbPedido" alignItems="Center" class="sapUiTinyMarginBottom">
                            <Label id="lblPedido" text="Pedido:" required="true" width="140px"/>
                            <Input
                                id="inpPedido"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpPedido"
                                change=".onInformacionValidacion"
                                width="100%"/>
                        </HBox>

                        <HBox id="hbHojaEntrada" alignItems="Center" class="sapUiTinyMarginBottom">
                            <Label id="lblHojaEntrada" text="Hoja de entrada / serv.:" required="true" width="140px"/>
                            <Input
                                id="inpHojaEntrada"
                                change=".onInformacionValidacion"
                                width="100%"/>
                        </HBox>

                        <HBox id="hbCentroCosto" alignItems="Center" class="sapUiTinyMarginBottom">
                            <Label id="lblCentroCosto" text="Centro coste:" required="true" width="140px"/>
                            <Input
                                id="inpCentroCosto"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpCentroCosto"
                                change=".onInformacionValidacion"
                                width="100%"/>
                        </HBox>

                        <HBox id="hbEjercicio" alignItems="Center" class="sapUiTinyMarginBottom">
                            <Label id="lblEjercicio" text="Ejercicio:" required="true" width="140px"/>
                            <Input
                                id="inpEjercicio"
                                change=".onInformacionValidacion"
                                width="100%"/>
                        </HBox>

                    </VBox>

                    <VBox id="vbColumnaDerecha">

                        <HBox id="hbMoneda" alignItems="Center" class="sapUiTinyMarginBottom">
                            <Label id="lblMoneda" text="Moneda:" required="true" width="140px"/>
                            <ComboBox
                                id="cmbMoneda"
                                selectionChange=".onInformacionValidacion"
                                width="100%">
                                <items>
                                    <core:Item id="itemMonedaDefault" key="" text="Seleccione..." />
                                    <core:Item id="itemMonedaArs" key="ARS" text="ARS" />
                                    <core:Item id="itemMonedaUsd" key="USD" text="USD" />
                                    <core:Item id="itemMonedaEur" key="EUR" text="EUR" />
                                </items>
                            </ComboBox>
                        </HBox>

                        <HBox id="hbImporte" alignItems="Center" class="sapUiTinyMarginBottom">
                            <Label id="lblImporte" text="Importe:" required="true" width="140px"/>
                            <Input
                                id="inpImporte"
                                type="Number"
                                change=".onInformacionValidacion"
                                width="100%"/>
                        </HBox>

                        <HBox id="hbReferencia" alignItems="Center" class="sapUiTinyMarginBottom">
                            <Label id="lblReferencia" text="Referencia:" width="140px"/>
                            <Input
                                id="inpReferencia"
                                change=".onInformacionValidacion"
                                width="100%"/>
                        </HBox>

                        <HBox id="hbCentroBeneficio" alignItems="Center" class="sapUiTinyMarginBottom">
                            <Label id="lblCentroBeneficio" text="Centro de Beneficio:" width="140px"/>
                            <Input
                                id="inpCentroBeneficio"
                                showValueHelp="true"
                                valueHelpRequest=".onValueHelpCentroBeneficio"
                                change=".onInformacionValidacion"
                                width="100%"/>
                        </HBox>

                    </VBox>

                </layout:Grid>

            </VBox>
        </Panel>

        <HBox
            id="bt6"
            justifyContent="Center"
            class="sapUiMediumMarginTop">

            <Button
                id="bt4"
                text="Paso anterior"
                press=".onPasoAnterior1"
                class="sapUiTinyMarginEnd"/>

            <Button
                id="bt5"
                text="Siguiente paso"
                type="Emphasized"
                press=".onSiguientePaso2"/>

        </HBox>

    </VBox>

</WizardStep>
                 <WizardStep id="TercerStep" title="Comentarios" validated="false" activate=".onComentariosValidacion">
                    <MessageStrip id="M3" class="sapUiSmallMarginBottom"
                                        type="Information"
										text="Agrega el comentario que creas necesario. Max caracteres 250"
										showIcon="true"/>
                    <form:SimpleForm id="ts2">
                       <TextArea id="txtComentario" placeholder="Escribí tu comentario aquí..." rows="5" maxLength="250" liveChange=".onComentariosValidacion" width="100%"/>

                    </form:SimpleForm>                
            
                    
        <HBox
            id="bt11"
            justifyContent="Center"
            class="sapUiMediumMarginTop">

            <Button
                id="bt12"
                text="Paso anterior"
                press=".onPasoAnterior2"
                class="sapUiTinyMarginEnd"/>

            <Button
                id="bt13"
                text="Siguiente paso"
                type="Emphasized"
                press=".onSiguientePaso3"/>

        </HBox>


                </WizardStep>

                 <WizardStep id="CuartoStep" title="Adjuntos" validated="true">
                    <MessageStrip id="M4" class="sapUiSmallMarginBottom"
										text="Ingresar los datos adjuntos"
										showIcon="true"/>
                                    
            
                </WizardStep>


                 <WizardStep id="QuintoStep" title="Revision" validated="true">
                    <MessageStrip id="M5" class="sapUiSmallMarginBottom"
										text="Revisar los datos ingresados en la solicitud"
										showIcon="true"/>
                                    
            
                </WizardStep>

        </Wizard>
        </content>
         <footer>
        <OverflowToolbar id="f1">

            <ToolbarSpacer id="ts1"/>

            <Button
                id="btnCancelarSolicitud"
                text="Cancelar solicitud"
                type="Reject"
                press=".onCancelarSolicitud"/>

        </OverflowToolbar>
    </footer>
    </Page>
</mvc:View>