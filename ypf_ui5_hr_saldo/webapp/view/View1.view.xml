                                    <core:Item id="itemMonedaReparoArs" key="ARS" text="ARS" />
                                    <core:Item id="itemMonedaReparoUsd" key="USD" text="USD" />
                                    <core:Item id="itemMonedaReparoEur" key="EUR" text="EUR" />
                                </items>
                            </ComboBox>
