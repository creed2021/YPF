                        class="sapUiTinyMarginBottom" />

                    <Table
                        id="tblSolicitudesReintegro"
                        width="100%"
                        inset="false"
                        noDataText="Sin datos">

                        <columns>
                            <Column id="colSolicitudReintegro" width="8rem">
                                <Text id="txtColSolicitudReintegro" text="Solicitud" />
                            </Column>
                            <Column id="colDocCreadoReintegro" width="8rem">
                                <Text id="txtColDocCreadoReintegro" text="Doc. Creado" />
                            </Column>
                            <Column id="colEjercicioReintegro" width="7rem">
                                <Text id="txtColEjercicioReintegro" text="Ejercicio" />
                            </Column>
                            <Column id="colSectorReintegro" width="7rem">
                                <Text id="txtColSectorReintegro" text="Sector" />
                            </Column>
                            <Column id="colSucursalReintegro" width="7rem">
                                <Text id="txtColSucursalReintegro" text="Sucursal" />
                            </Column>
                            <Column id="colUbicacionReintegro" width="8rem">
                                <Text id="txtColUbicacionReintegro" text="Ubicación" />
                            </Column>
                            <Column id="colImporteReintegro" width="7rem" hAlign="End">
                                <Text id="txtColImporteReintegro" text="Importe" />
                            </Column>
                            <Column id="colMonedaReintegro" width="6rem">
                                <Text id="txtColMonedaReintegro" text="Moneda" />
                            </Column>
                            <Column id="colCebeReintegro" width="6rem">
                                <Text id="txtColCebeReintegro" text="CEBE" />
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem id="cliSolicitudesReintegro">
                                <cells>
                                    <Text id="txtSolicitudReintegro" text="" />
                                    <Text id="txtDocCreadoReintegro" text="" />
                                    <Text id="txtEjercicioReintegro" text="" />
                                    <Text id="txtSectorReintegro" text="" />
                                    <Text id="txtSucursalReintegro" text="" />
                                    <Text id="txtUbicacionReintegro" text="" />
                                    <Text id="txtImporteReintegro" text="" />
                                    <Text id="txtMonedaReintegro" text="" />
                                    <Text id="txtCebeReintegro" text="" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>

            </layout:Grid>

        </VBox>
    </Panel>

    <HBox
        id="boxAccionesInformacionReintegro"
        justifyContent="Center"
        class="sapUiMediumMarginTop">

        <Button
            id="btnAnteriorInformacionReintegro"
            text="Paso anterior"
            press=".onPasoAnterior1"
            class="sapUiTinyMarginEnd" />

        <Button
            id="btnSiguienteInformacionReintegro"
            text="Siguiente paso"
            type="Emphasized"
            press=".onSiguientePaso2" />
    </HBox>

</VBox>

<VBox id="vbfr" visible="{ui>/showFondoReparo}" class="sapUiSmallMargin">

    <Panel id="pfr1"
        headerText="Datos de cabecera"
        expandable="true"
        expanded="true"
        class="sapUiResponsiveMargin">

        <VBox id="vb1" class="sapUiSmallMargin">

            <Button id="bfr"
                text="Fondo de Reparo"
                type="Transparent"
                icon="sap-icon://add"
                class="sapUiTinyMarginBottom" />

            <HBox justifyContent="Center" width="100%">
